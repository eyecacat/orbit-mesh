modules = ["nodejs-20", "nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 6000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 8083
externalPort = 3003

[[ports]]
localPort = 8084
externalPort = 4200

[[ports]]
localPort = 8085
externalPort = 5000

[[ports]]
localPort = 8086
externalPort = 5173

[[ports]]
localPort = 22381
externalPort = 3000

[[ports]]
localPort = 22382
externalPort = 3001

[userenv]

[userenv.shared]
EXPO_PUBLIC_NASA_API_KEY = "2WkZpDe6vPf9N5OHceramFpvJ1us7K5nZMXXdtEw"

[nix]
packages = ["tree", "nano", "watchman", "zulu8"]
